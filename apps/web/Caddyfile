:{$PORT:5173} {
	root * /usr/share/caddy
	encode zstd gzip

	@api path /health /auth* /sessions* /events* /webhooks*
	handle @api {
		reverse_proxy {$API_UPSTREAM:http://api:3583}
	}

	@assets path /assets/*
	handle @assets {
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	handle {
		header Cache-Control "no-cache"
		try_files {path} /index.html
		file_server
	}
}
