{
  "name": "deputies-control-plane",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "auth:login:openai-codex": "tsx src/runner-flue/openai-codex-login.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "demo:export": "tsx src/scripts/export-static-demo.ts",
    "docker-orchestrator:dev": "tsx watch src/sandbox/docker-orchestrator-server.ts",
    "docker-orchestrator:start": "node dist/sandbox/docker-orchestrator-server.js",
    "k8s-agent-sandbox-orchestrator:dev": "tsx watch src/sandbox/k8s-agent-sandbox-orchestrator-server.ts",
    "k8s-agent-sandbox-orchestrator:start": "node dist/sandbox/k8s-agent-sandbox-orchestrator-server.js",
    "dev": "tsx watch src/index.ts",
    "emulate:slack": "emulate start --service slack --portless",
    "portless:start": "pnpm dlx portless proxy start --wildcard",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:load": "vitest run --config vitest.load.config.ts",
    "test:uat": "vitest run --config vitest.uat.config.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@daytona/sdk": "^0.185.0",
    "@deputies/browser-milestones": "workspace:*",
    "@earendil-works/pi-ai": "0.74.0",
    "@earendil-works/pi-coding-agent": "0.78.0",
    "@flue/runtime": "0.11.1",
    "@hono/node-server": "^2.0.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.217.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.217.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-metrics": "^2.2.0",
    "@opentelemetry/sdk-node": "^0.217.0",
    "hono": "^4.12.18",
    "pg": "^8.20.0",
    "tensorlake": "^0.5.40"
  },
  "devDependencies": {
    "@types/node": "^22.10.10",
    "@types/pg": "^8.20.0",
    "emulate": "^0.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2",
    "vitest": "^4.1.5"
  }
}
