---
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatBlogDate, getBlogPostSlug, getBlogPostUrl, getPublishedBlogPosts, type BlogPost } from '../../lib/blog';

export async function getStaticPaths() {
  const posts = await getPublishedBlogPosts();
  return posts.map((post, index) => ({
    params: { slug: getBlogPostSlug(post) },
    props: { post, previousPost: posts[index + 1], nextPost: posts[index - 1] },
  }));
}

const { post, previousPost, nextPost } = Astro.props as {
  post: BlogPost;
  previousPost?: BlogPost;
  nextPost?: BlogPost;
};
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} | Deputies Blog`}
  description={post.data.description}
  canonicalPath={getBlogPostUrl(post)}
  type="article"
  current="blog"
>
  <article class="post-shell">
    <header class="post-header">
      <a class="back-link" href="/blog/">Blog</a>
      <p class="eyebrow">Deputies Blog</p>
      <h1>{post.data.title}</h1>
      <p class="post-description">{post.data.description}</p>
      <p class="post-meta">
        <time datetime={post.data.pubDate.toISOString()}>{formatBlogDate(post.data.pubDate)}</time>
        <span>{post.data.author}</span>
        {
          post.data.updatedDate && (
            <span>
              Updated{' '}
              <time datetime={post.data.updatedDate.toISOString()}>{formatBlogDate(post.data.updatedDate)}</time>
            </span>
          )
        }
      </p>
    </header>
    <div class="post-body">
      <Content />
    </div>
    {
      (previousPost || nextPost) && (
        <nav class="post-navigation" aria-label="Blog post navigation">
          {previousPost && (
            <a class="post-navigation__card" href={getBlogPostUrl(previousPost)}>
              <span class="post-navigation__label">Previous post</span>
              <strong>{previousPost.data.title}</strong>
            </a>
          )}
          {nextPost && (
            <a class="post-navigation__card post-navigation__card--next" href={getBlogPostUrl(nextPost)}>
              <span class="post-navigation__label">Next post</span>
              <strong>{nextPost.data.title}</strong>
            </a>
          )}
        </nav>
      )
    }
  </article>
</BaseLayout>
