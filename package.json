{
  "name": "deputies",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "prepare": "node -e \"const fs=require('fs'); if (fs.existsSync('.git') && process.env.NODE_ENV !== 'production') require('child_process').execFileSync('pnpm', ['exec', 'husky'], { stdio: 'inherit' })\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "check": "pnpm format:check && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.7.4",
    "prettier-plugin-astro": "^0.14.1"
  }
}
